# App
APP_NAME=gin-clean-template
APP_VERSION=1.0.0
APP_ENV=local
# Transports
HTTP_ENABLED=true
GRPC_ENABLED=false
RMQ_ENABLED=false
NATS_ENABLED=false
# HTTP
HTTP_PORT=8080
# gRPC
GRPC_PORT=8081
# RMQ
RMQ_RPC_SERVER=rpc_server
RMQ_RPC_CLIENT=rpc_client
RMQ_URL=amqp://guest:guest@localhost:5672/
# NATS
NATS_RPC_SERVER=rpc_server
NATS_URL=nats://guest:guest@localhost:4222/
# Logger
LOG_LEVEL=debug
# PG
PG_POOL_MAX=2
PG_URL=postgres://user:myAwEsOm3pa55@w0rd@localhost:5432/db
# Metrics
METRICS_ENABLED=true
# Swagger
SWAGGER_ENABLED=true
# Trace
TRACE_ENABLED=false
TRACE_EXPORTER=stdout
TRACE_SERVICE_NAME=gin-clean-template
# Outbox
OUTBOX_ENABLED=false
OUTBOX_PUBLISHER=nats
OUTBOX_NATS_URL=
OUTBOX_SUBJECT_PREFIX=events
OUTBOX_POLL_INTERVAL=1s
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_LOCK_TIMEOUT=5m
OUTBOX_PUBLISH_TIMEOUT=5s
# JWT
JWT_TOKEN_EXPIRY=24h
JWT_SECRET=your-secret-key-change-in-production
