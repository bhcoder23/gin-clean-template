# App
APP_NAME=gin-clean-template
APP_VERSION=1.0.0
# Transports
HTTP_ENABLED=true
GRPC_ENABLED=true
RMQ_ENABLED=true
NATS_ENABLED=true
# HTTP
HTTP_PORT=8080
# gRPC
GRPC_PORT=8081
# RMQ
RMQ_RPC_SERVER=rpc_server
RMQ_RPC_CLIENT=rpc_client
RMQ_URL=amqp://guest:guest@localhost:5672/
# NATS
NATS_RPC_SERVER=rpc_server
NATS_URL=nats://guest:guest@localhost:4222/
# Logger
LOG_LEVEL=debug
# PG
PG_POOL_MAX=2
PG_URL=postgres://user:myAwEsOm3pa55@w0rd@localhost:5432/db
# Metrics
METRICS_ENABLED=true
# Swagger
SWAGGER_ENABLED=true
# JWT
JWT_TOKEN_EXPIRY=24h
JWT_SECRET=your-secret-key-change-in-production
